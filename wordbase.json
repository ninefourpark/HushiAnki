        "dialogue_chain": [
          {

            "content": [
              "Nice to meet you!",
              "Nice to meet you too!"
            ],
            "id": "c7f65535"
          },
          {

            "content": [
              "What's your favorite season?",
              "I love winter because of the snow."
            ],
            "id": "fdbf74ad"
          },
          {

            "content": [
              "Do you think it's going to rain?",
              "The sky is grey. So, yes, definitely."
            ],
            "id": "c13c3644"
          },
          {

            "content": [
              "Could I get the check, please?",
              "Of course! Cash or card?"
            ],
            "id": "d251e811"
          },
          {

            "content": [
              "Excuse me, is there a pharmacy nearby?",
              "Yes, go straight and turn left at the supermarket."
            ],
            "id": "d40dfa19"
          },
          {

            "content": [
              "Hi, welcome! Can I start you off with a drink?",
              "Just water, please."
            ],
            "id": "b7b10549"
          },
          {

            "content": [
              "Does your dog know any tricks?",
              "He can make a whole steak disappear in 3 seconds."
            ],
            "id": "d143744d"
          },
          {

            "content": [
              "It's freezing outside today!",
              "Tell me about it. My coffee turned into an ice cream in two minutes."
            ],
            "id": "f740518c"
          },
          {

            "content": [
              "Is this your first time here?",
              "Yes, a friend recommended it.",
              "Good friend. You should keep them."
            ],
            "id": "afd043ea"
          },
          {

            "content": [
              "Just a trim, please. Don't take too much off the top.",
              "You got it. Long enough to hide your ears?",
              "Exactly. I'm not ready to show them to the world yet."
            ],
            "id": "b30949e8"
          },
          {

            "content": [
              "Is this seat taken?",
              "No, it’s free.",
              "Great! I thought I was going to have to stand on one leg."
            ],
            "id": "421eeed3"
          },
          {

            "content": [
              "You're late again. Traffic?",
              "No, my bed was holding me hostage.",
              "Thats a serious crime."
            ],
            "id": "d4eb495f"
          },
          {

            "content": [
              "What is your greatest weakness?",
              "Sometimes I'm too perfectionist.",
              "That's a classic answer. Anything real?",
              "Okay, I can't start my brain without three cups of coffee."
            ],
            "id": "21b7b956"
          },
          {

            "content": [
              "Is the neighborhood quiet at night?",
              "Oh, absolutely. Except for the jazz club downstairs.",
              "Do they play well?",
              "Well enough that you won't need a TV."
            ],
            "id": "815d6581"
          },
          {

            "content": [
              "I think I left my umbrella here last Tuesday.",
              "Can you describe it?",
              "Black. Foldable. Has a tiny duck on the handle.",
              "We actually have three of those. Which duck?"
            ],
            "id": "4c4a67db"
          }
        ]
